# Copy this file to `.env.local` and fill in real values from your Supabase project.
# (.env.local is gitignored — never commit real keys.)

# Supabase → Project Settings → API
# Safe to expose to the browser (protected by Row Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret. NEVER prefix with NEXT_PUBLIC_ and never ship to the browser.
# Bypasses RLS — used only in trusted server code (e.g. the Resend welcome email step).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Resend → API Keys (used in Phase 5 for the welcome email)
RESEND_API_KEY=your-resend-api-key
# Verified sender address (or Resend's onboarding@resend.dev for testing)
EMAIL_FROM=Bookmarks <onboarding@resend.dev>
