# Copy this file to `.env.local` and fill in real values from your Supabase project.
# (.env.local is gitignored — never commit real keys.)

# Supabase → Project Settings → API
# Safe to expose to the browser (protected by Row Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret. NEVER prefix with NEXT_PUBLIC_ and never ship to the browser.
# Bypasses RLS — used only in trusted server code (e.g. the Resend welcome email step).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Resend → API Keys (used for the welcome email on signup)
RESEND_API_KEY=your-resend-api-key
# Sender address. Use an address on a domain you've VERIFIED in Resend so mail
# delivers to any recipient. onboarding@resend.dev works too, but only delivers
# to your own Resend account email (test mode).
EMAIL_FROM=Bookmarks <noreply@your-verified-domain.com>
